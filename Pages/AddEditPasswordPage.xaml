<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PasswordManager.Pages.AddEditPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource AppBackground}"
    NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,Auto" Padding="0">

        <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Default">
            <Grid HorizontalOptions="Center"
                  WidthRequest="520"
                  Padding="0,40,0,24">
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="0">

                        <!-- Header -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,32">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label x:Name="PageTitleLabel"
                                       Text="Yangi parol qo'shish"
                                       Style="{StaticResource HeadingStyle}"
                                       FontSize="20" />
                                <Label Text="Barcha ma'lumotlar shifrlangan holda saqlanadi"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="12" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="✕"
                                    Style="{StaticResource IconButtonStyle}"
                                    Clicked="OnCancel_Clicked"
                                    VerticalOptions="Start" />
                        </Grid>

                        <!-- Service name -->
                        <Label Text="XIZMAT NOMI *" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" />
                        <Border Background="{StaticResource InputBg}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource BorderColor}"
                                Padding="14,0"
                                Margin="0,0,0,20">
                            <Entry x:Name="ServiceEntry"
                                   Style="{StaticResource InputStyle}"
                                   Placeholder="Google, Facebook, GitHub..."
                                   ReturnType="Next" />
                        </Border>

                        <!-- Password -->
                        <Label Text="PAROL *" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" />
                        <Border Background="{StaticResource InputBg}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource BorderColor}"
                                Padding="14,0"
                                Margin="0,0,0,4">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <Entry x:Name="PasswordEntry"
                                       Grid.Column="0"
                                       Style="{StaticResource InputStyle}"
                                       Placeholder="Parolni kiriting"
                                       IsPassword="True"
                                       ReturnType="Next"
                                       TextChanged="OnPasswordTextChanged" />
                                <Button Grid.Column="1"
                                        x:Name="TogglePwBtn"
                                        Text="👁"
                                        Style="{StaticResource IconButtonStyle}"
                                        Clicked="OnTogglePassword_Clicked" />
                                <Button Grid.Column="2"
                                        Text="⚡"
                                        Style="{StaticResource IconButtonStyle}"
                                        TextColor="{StaticResource AccentPrimary}"
                                        Clicked="OnQuickGenerate_Clicked" />
                            </Grid>
                        </Border>

                        <!-- Strength bar -->
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="4" Margin="0,8,0,4">
                            <BoxView x:Name="PwStrength1" Grid.Column="0" HeightRequest="4" Color="{StaticResource BorderColor}" CornerRadius="2" />
                            <BoxView x:Name="PwStrength2" Grid.Column="1" HeightRequest="4" Color="{StaticResource BorderColor}" CornerRadius="2" />
                            <BoxView x:Name="PwStrength3" Grid.Column="2" HeightRequest="4" Color="{StaticResource BorderColor}" CornerRadius="2" />
                            <BoxView x:Name="PwStrength4" Grid.Column="3" HeightRequest="4" Color="{StaticResource BorderColor}" CornerRadius="2" />
                        </Grid>
                        <Label x:Name="PwStrengthLabel"
                               Text=" "
                               FontSize="11"
                               TextColor="{StaticResource TextMuted}"
                               Margin="0,0,0,20" />

                        <!-- Folder (optional) -->
                        <Label Text="PAPKA (ixtiyoriy)" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" />
                        <Border Background="{StaticResource InputBg}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource BorderColor}"
                                Padding="14,0"
                                Margin="0,0,0,20">
                            <Picker x:Name="FolderPicker"
                                    Title="Papka tanlang..."
                                    TitleColor="{StaticResource TextMuted}"
                                    TextColor="{StaticResource TextPrimary}"
                                    BackgroundColor="Transparent"
                                    HeightRequest="52" />
                        </Border>

                        <!-- Username (optional) -->
                        <Label Text="FOYDALANUVCHI NOMI (ixtiyoriy)" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" />
                        <Border Background="{StaticResource InputBg}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource BorderColor}"
                                Padding="14,0"
                                Margin="0,0,0,20">
                            <Entry x:Name="UsernameEntry"
                                   Style="{StaticResource InputStyle}"
                                   Placeholder="Foydalanuvchi nomi yoki login"
                                   ReturnType="Next" />
                        </Border>

                        <!-- Email (optional) -->
                        <Label Text="EMAIL (ixtiyoriy)" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" />
                        <Border Background="{StaticResource InputBg}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource BorderColor}"
                                Padding="14,0"
                                Margin="0,0,0,20">
                            <Entry x:Name="EmailEntry"
                                   Style="{StaticResource InputStyle}"
                                   Placeholder="email@misol.com"
                                   Keyboard="Email"
                                   ReturnType="Next" />
                        </Border>

                        <!-- Phone (optional) -->
                        <Label Text="TELEFON (ixtiyoriy)" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" />
                        <Border Background="{StaticResource InputBg}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource BorderColor}"
                                Padding="14,0"
                                Margin="0,0,0,28">
                            <Entry x:Name="PhoneEntry"
                                   Style="{StaticResource InputStyle}"
                                   Placeholder="+998 90 123 45 67"
                                   Keyboard="Telephone"
                                   ReturnType="Done"
                                   Completed="OnSave_Clicked" />
                        </Border>

                        <!-- Error -->
                        <Label x:Name="ErrorLabel"
                               Text=""
                               TextColor="{StaticResource Danger}"
                               FontSize="13"
                               HorizontalOptions="Center"
                               Margin="0,0,0,16" />

                        <!-- Buttons -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Grid.Column="0"
                                    Text="Bekor qilish"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Clicked="OnCancel_Clicked" />
                            <Button Grid.Column="1"
                                    x:Name="SaveButton"
                                    Text="Saqlash"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Clicked="OnSave_Clicked" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>

        <!-- Loading overlay -->
        <Grid Grid.RowSpan="2"
              x:Name="LoadingOverlay"
              IsVisible="False"
              Background="#88000000">
            <ActivityIndicator IsRunning="True"
                               Color="{StaticResource AccentPrimary}"
                               WidthRequest="48" HeightRequest="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>

    </Grid>
</ContentPage>
