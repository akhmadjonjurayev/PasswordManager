<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PasswordManager.Pages.PasswordDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource AppBackground}"
    NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <Grid HorizontalOptions="Center" WidthRequest="480" Padding="20,40,20,40">

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="0">

                    <!-- Header -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,32">

                        <Border Grid.Column="0"
                                Background="{StaticResource NavItemActive}"
                                StrokeShape="RoundRectangle 14"
                                Stroke="Transparent"
                                WidthRequest="52" HeightRequest="52">
                            <Label Text="🌐"
                                   FontSize="24"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="3" Margin="14,0,0,0" VerticalOptions="Center">
                            <Label x:Name="ServiceNameLabel"
                                   Text="Service"
                                   Style="{StaticResource HeadingStyle}"
                                   FontSize="20" />
                            <Label x:Name="DateLabel"
                                   Text=""
                                   Style="{StaticResource SubheadingStyle}"
                                   FontSize="11" />
                        </VerticalStackLayout>

                        <Button Grid.Column="2"
                                Text="✕"
                                Style="{StaticResource IconButtonStyle}"
                                Clicked="OnClose_Clicked"
                                VerticalOptions="Start" />
                    </Grid>

                    <!-- Password field -->
                    <Label Text="PAROL" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" />
                    <Border Background="{StaticResource InputBg}"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource BorderColor}"
                            Padding="16,0"
                            Margin="0,0,0,20">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Label x:Name="PasswordDisplayLabel"
                                   Grid.Column="0"
                                   Text="••••••••••••"
                                   FontSize="18"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center"
                                   HeightRequest="52" />
                            <Button Grid.Column="1"
                                    x:Name="RevealBtn"
                                    Text="👁"
                                    Style="{StaticResource IconButtonStyle}"
                                    Clicked="OnRevealPassword_Clicked" />
                            <Button Grid.Column="2"
                                    Text="📋"
                                    Style="{StaticResource IconButtonStyle}"
                                    Clicked="OnCopyPassword_Clicked" />
                        </Grid>
                    </Border>

                    <!-- Username field (conditional) -->
                    <VerticalStackLayout x:Name="UsernameSection" IsVisible="False" Spacing="0">
                        <Label Text="FOYDALANUVCHI NOMI" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" />
                        <Border Background="{StaticResource InputBg}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource BorderColor}"
                                Padding="16,0"
                                Margin="0,0,0,20">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="UsernameDisplayLabel"
                                       Grid.Column="0"
                                       Text=""
                                       FontSize="14"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center"
                                       HeightRequest="48" />
                                <Button Grid.Column="1"
                                        Text="📋"
                                        Style="{StaticResource IconButtonStyle}"
                                        Clicked="OnCopyUsername_Clicked" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Email field (conditional) -->
                    <VerticalStackLayout x:Name="EmailSection" IsVisible="False" Spacing="0">
                        <Label Text="EMAIL" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" />
                        <Border Background="{StaticResource InputBg}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource BorderColor}"
                                Padding="16,0"
                                Margin="0,0,0,20">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="EmailDisplayLabel"
                                       Grid.Column="0"
                                       Text=""
                                       FontSize="14"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center"
                                       HeightRequest="48" />
                                <Button Grid.Column="1"
                                        Text="📋"
                                        Style="{StaticResource IconButtonStyle}"
                                        Clicked="OnCopyEmail_Clicked" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Phone field (conditional) -->
                    <VerticalStackLayout x:Name="PhoneSection" IsVisible="False" Spacing="0">
                        <Label Text="TELEFON" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" />
                        <Border Background="{StaticResource InputBg}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource BorderColor}"
                                Padding="16,0"
                                Margin="0,0,0,20">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="PhoneDisplayLabel"
                                       Grid.Column="0"
                                       Text=""
                                       FontSize="14"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center"
                                       HeightRequest="48" />
                                <Button Grid.Column="1"
                                        Text="📋"
                                        Style="{StaticResource IconButtonStyle}"
                                        Clicked="OnCopyPhone_Clicked" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Error -->
                    <Label x:Name="ErrorLabel"
                           Text=""
                           TextColor="{StaticResource Danger}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           Margin="0,0,0,16" />

                    <!-- Close button -->
                    <Button Text="Yopish"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Clicked="OnClose_Clicked"
                            HorizontalOptions="Fill" />

                </VerticalStackLayout>
            </Border>

        </Grid>
    </ScrollView>
</ContentPage>
